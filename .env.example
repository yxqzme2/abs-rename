# -------------------------------------------------------
# ABS Rename — environment configuration
# Copy this file to .env and adjust values as needed.
# -------------------------------------------------------

# Absolute path to the SQLite database file.
# Leave blank to use the default: ./abs_rename.db
DATABASE_PATH=

# Default output folder for renamed/copied files.
# Can be overridden per-session in the UI.
DEFAULT_OUTPUT_FOLDER=

# AudNexus API base URL (change only if self-hosting AudNexus).
AUDNEXUS_BASE_URL=https://api.audnexus.app

# AudNexus region (us, uk, au, ca, de, fr, it, es, jp, in).
# Affects which Audible region is searched.
AUDNEXUS_REGION=us

# Delay in milliseconds between AudNexus requests during a batch scan.
# Increase if you see rate-limit errors (HTTP 429).
AUDNEXUS_REQUEST_DELAY_MS=400

# Confidence threshold for auto-approving a match (0–100).
# Items at or above this score are pre-checked in the results UI.
CONFIDENCE_AUTO_APPROVE=90

# Confidence threshold below which items are flagged "review required".
CONFIDENCE_REVIEW_REQUIRED=75

# Host and port for the local web server.
HOST=127.0.0.1
PORT=8000

# Set to "true" to enable verbose debug logging.
DEBUG=false

# MP3 hand-off folder (separate Unraid share / path for external converter container).
# Leave blank to disable MP3 hand-off feature.
MP3_HANDOFF_FOLDER=

# Whether to match MP3 files via AudNexus (same scoring as M4B).
# If true, MP3s appear in results for user approval before hand-off.
MATCH_MP3_FILES=true
